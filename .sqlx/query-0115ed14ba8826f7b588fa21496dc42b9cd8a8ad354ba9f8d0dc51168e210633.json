  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.id, u.email::text AS \"email\", u.password_hash, u.display_name,\n               r.name AS role_name,\n               u.is_active, u.email_verified, u.created_at, u.updated_at\n        FROM users u JOIN roles r ON r.id = u.role_id\n        WHERE u.email = $1\n        ",
