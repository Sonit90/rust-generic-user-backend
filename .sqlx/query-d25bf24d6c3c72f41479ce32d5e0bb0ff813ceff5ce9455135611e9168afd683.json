  "query": "\n        SELECT u.id, u.email::text AS \"email\", u.display_name, r.name AS role_name,\n               u.is_active, u.email_verified, u.created_at, u.updated_at\n        FROM users u JOIN roles r ON r.id = u.role_id\n        WHERE u.id = $1\n        ",
