# Copy to .env for local dev. Loaded by docker-compose and (optionally) by the app via dotenvy.

# --- Runtime ---
APP_ENV=development        # development | production | test
RUST_LOG=info,price_merger=debug,sqlx=warn

# --- HTTP ---
APP__HTTP__BIND=0.0.0.0:8080
APP__HTTP__PUBLIC_URL=http://localhost:8080
APP__HTTP__FRONTEND_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://price_merger:price_merger@postgres:5432/price_merger
APP__DB__MAX_CONNECTIONS=20

# --- Object storage (RustFS / MinIO / any S3-compatible) ---
APP__STORAGE__ENDPOINT=http://rustfs:9000
APP__STORAGE__REGION=us-east-1
APP__STORAGE__BUCKET=price-merger
APP__STORAGE__ACCESS_KEY=price_merger
APP__STORAGE__SECRET_KEY=price_merger_secret
APP__STORAGE__USE_PATH_STYLE=true

# --- File retention ---
# How long uploaded files stay before the purge job removes them.
APP__FILES__TTL_HOURS=72
APP__FILES__MAX_UPLOAD_MB=50

# --- Auth ---
APP__AUTH__JWT_SECRET=change-me-to-a-long-random-string
APP__AUTH__JWT_ACCESS_TTL_MIN=30
APP__AUTH__JWT_REFRESH_TTL_DAYS=14

# --- OAuth providers (optional — leave blank to disable) ---
APP__AUTH__GOOGLE__CLIENT_ID=
APP__AUTH__GOOGLE__CLIENT_SECRET=
APP__AUTH__GOOGLE__REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/google/callback

# --- Jobs ---
APP__JOBS__WORKERS=4
APP__JOBS__POLL_INTERVAL_SECS=5

# --- Email (SMTP — works with any provider) ---
# Leave SMTP_HOST blank to disable sending (dev mode — link logged to stdout).
# Mailjet:  in-v3.mailjet.com:587  username=api_key   password=api_secret
# SendGrid: smtp.sendgrid.net:587  username=apikey    password=<sendgrid_key>
# Mailgun:  smtp.mailgun.org:587   username=<user>    password=<password>
APP__EMAIL__SMTP_HOST=
APP__EMAIL__SMTP_PORT=587
APP__EMAIL__SMTP_USERNAME=
APP__EMAIL__SMTP_PASSWORD=
APP__EMAIL__FROM_EMAIL=noreply@example.com
APP__EMAIL__FROM_NAME=PriceMerger
