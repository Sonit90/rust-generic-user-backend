# Copy this to .env and fill in the values for local development

APP_ENV=development
RUST_LOG=info,generic_auth=debug,sqlx=warn

# PostgreSQL credentials (used by docker compose + DATABASE_URL below)
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=auth_password
POSTGRES_DB=auth_db
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5434

# Database (required for local runs; for docker, api builds its own URL from POSTGRES_* above)
DATABASE_URL=postgres://auth_user:auth_password@localhost:5434/auth_db

# Authentication
APP__AUTH__JWT_SECRET=qidnPfBGZkdwC1cYc78wqVR9my2v2NxGR6iBRnPSkWPMPrdPNT7KuLJq2bLLvjTXA1gpahPLrLiTaNGLDKwGvV41jTwwDhrgpfdv
APP__AUTH__JWT_ACCESS_TTL_MIN=30
APP__AUTH__JWT_REFRESH_TTL_DAYS=14
APP__AUTH__PASSWORD_MIN_LENGTH=8

# OAuth (optional - leave blank to disable)
APP__AUTH__GOOGLE__CLIENT_ID=
APP__AUTH__GOOGLE__CLIENT_SECRET=
APP__AUTH__GOOGLE__REDIRECT_URL=

# Email (optional - leave SMTP_HOST blank for dev mode, logs to stdout instead)
APP__EMAIL__SMTP_HOST=
APP__EMAIL__SMTP_PORT=587
APP__EMAIL__SMTP_USERNAME=
APP__EMAIL__SMTP_PASSWORD=
APP__EMAIL__FROM_EMAIL=noreply@example.com
APP__EMAIL__FROM_NAME=Auth Service

# CORS (dev mode: use ["*"])
APP__CORS__ALLOWED_ORIGINS=
